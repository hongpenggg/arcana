# Gemini API Configuration (server-side only — set in Vercel dashboard, NOT prefixed with VITE_)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Configuration (server-side only — set in Vercel dashboard, NOT prefixed with VITE_)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Your deployed site URL for OpenRouter rankings
SITE_URL=https://your-vercel-deployment.vercel.app
